# Server
PORT=3001
NODE_ENV=development

# Database
DB_TYPE=sqlite
DB_PATH=./db/dev.sqlite3

# JWT
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRES_IN=7d

# AI / LLM
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
